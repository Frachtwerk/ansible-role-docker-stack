# env file for watchtower
TZ={{ watchtower_timezone }}
WATCHTOWER_LOG_LEVEL=info  # panic, fatal, error, warn, info, debug, trace
WATCHTOWER_LOG_FORMAT=Auto  # Auto, LogFmt, Pretty, JSON
NO_COLOR=false
WATCHTOWER_RUN_ONCE=false
WATCHTOWER_UPDATE_ON_START=false
{% if watchtower_schedule | length %}
WATCHTOWER_SCHEDULE={{ watchtower_schedule }}
{% endif %}
{% if watchtower_poll_interval | length %}
WATCHTOWER_POLL_INTERVAL={{ watchtower_poll_interval }}
{% endif %}
WATCHTOWER_INCLUDE_STOPPED=false
WATCHTOWER_REVIVE_STOPPED=false
WATCHTOWER_INCLUDE_RESTARTING=false
WATCHTOWER_NO_RESTART=false
WATCHTOWER_ROLLING_RESTART=true
WATCHTOWER_CLEANUP=false
WATCHTOWER_REMOVE_VOLUMES=false
WATCHTOWER_MONITOR_ONLY=false
WATCHTOWER_NO_PULL=false
# TODO:
WATCHTOWER_LABEL_ENABLE=false
# TODO:
WATCHTOWER_DISABLE_CONTAINERS
WATCHTOWER_LABEL_TAKE_PRECEDENCE=false

# WATCHTOWER_SCOPE
# REPO_USER
# REPO_PASS
# DOCKER_CONFIG
WATCHTOWER_REGISTRY_TLS_SKIP=false
# WATCHTOWER_REGISTRY_TLS_MIN_VERSION=
# HTTP_PROXY
# HTTPS_PROXY
# NO_PROXY
# WATCHTOWER_WARN_ON_HEAD_FAILURE=auto  # always, auto, never
# DOCKER_HOST=unix:///var/run/docker.sock
# DOCKER_TLS_VERIFY=false
# WATCHTOWER_DISABLE_MEMORY_SWAPPINESS=false
# WATCHTOWER_CPU_COPY_MODE=auto  # auto, full, none
{% if watchtower_enable_api | bool %}
WATCHTOWER_HTTP_API_PERIODIC_POLLS=true
WATCHTOWER_HTTP_API_UPDATE=true
{% if watchtower_api_token | length %}
WATCHTOWER_HTTP_API_TOKEN={{ watchtower_api_token }}
{% endif %}
# WATCHTOWER_HTTP_API_METRICS=false  # Prometheus
# WATCHTOWER_HTTP_API_HOST=
# WATCHTOWER_HTTP_API_PORT=8080
{% endif %}

# Notifications:
# TODO
WATCHTOWER_NOTIFICATION_EMAIL_SERVER_PASSWORD=
WATCHTOWER_NOTIFICATION_GOTIFY_TOKEN=
WATCHTOWER_NOTIFICATION_MSTEAMS_HOOK=
WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=
WATCHTOWER_NOTIFICATION_URL=
